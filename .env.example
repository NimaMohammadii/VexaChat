# Example environment variables
# For Render + Supabase, prefer the Supabase "Session pooler" URL (port 6543)
# and include sslmode=require to avoid "Can't reach database server" on deploy.
# Example:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require"
DATABASE_URL=""
DIRECT_URL=""
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Public app URL used for OAuth redirect targets
NEXT_PUBLIC_APP_URL="https://vexachat-e9nm.onrender.com"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com" # Account endpoint only (no bucket name)
